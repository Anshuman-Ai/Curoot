# ------------------------------------------------------------------
# Supabase Configuration
# ------------------------------------------------------------------
# Publicly safe: Use this in frontend and backend
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# SENSITIVE: Never expose this in the frontend. 
# Use only in backend or secure scripts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------------------------------
# AI Services
# ------------------------------------------------------------------
# Google Gemini API Key (Backend only)
GEMINI_API_KEY=your-gemini-api-key

# ------------------------------------------------------------------
# External API Keys (Backend only)
# ------------------------------------------------------------------
# NewsAPI Key — https://newsapi.org
NEWSAPI_KEY=your-newsapi-key

# Reddit OAuth2 — https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret

# OpenRouteService — https://openrouteservice.org
OPENROUTE_KEY=your-openroute-key

# ------------------------------------------------------------------
# Database (if applicable)
# ------------------------------------------------------------------
DB_USER=postgres
DB_PASS=your-db-password
DB_NAME=postgres
DB_HOST=db.your-project.supabase.co
DB_PORT=5432
