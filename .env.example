# ──────────────────────────────────────────────
# Curoot — Environment Variables Template
# Copy this to .env and fill in your real values
# ──────────────────────────────────────────────

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI / LLM
GEMINI_API_KEY=your_gemini_api_key

# External APIs
NEWSAPI_KEY=your_newsapi_key
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
OPENROUTE_KEY=your_openroute_key

# MCP Connector (optional — for docker-compose mcp profile)
# MCP_DB_TYPE=postgres
# MCP_DB_IP=host.docker.internal
# MCP_DB_PORT=5432
# MCP_DB_USER=readonly_user
# MCP_DB_PASS=
# MCP_DB_NAME=erp
# MCP_TABLE=inventory
# MCP_SYNC_FREQ=60
